{$DOMAIN:localhost} {
    encode gzip

    # API REST
    handle /api/* {
        reverse_proxy api:3000
    }

    # Archivos estáticos del frontend (SPA)
    handle {
        root * /srv/web
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
